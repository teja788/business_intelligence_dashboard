{
  "name": "vantage",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Vantage — a web-based, local-first data-exploration & dashboarding tool",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
